<?xml version="1.0" encoding="UTF-8" ?>
<ResourceDictionary
    xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
    xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml">

    <!-- Brand — warm salmon accent (PesaSense style) -->
    <Color x:Key="Primary">#F4A28A</Color>
    <Color x:Key="PrimaryDark">#C07060</Color>
    <Color x:Key="PrimaryLight">#3D1A15</Color>

    <!-- Semantic -->
    <Color x:Key="Danger">#EF4444</Color>
    <Color x:Key="Warning">#F59E0B</Color>
    <Color x:Key="Success">#10B981</Color>

    <!-- Dark warm surface hierarchy -->
    <Color x:Key="Background">#1C0A09</Color>
    <Color x:Key="Surface">#2C1515</Color>
    <Color x:Key="SurfaceVariant">#3D2020</Color>
    <Color x:Key="Divider">#4D2828</Color>

    <!-- Text on dark warm -->
    <Color x:Key="TextPrimary">#F1E8E6</Color>
    <Color x:Key="TextSecondary">#B8948A</Color>
    <Color x:Key="TextHint">#7A5250</Color>
    <Color x:Key="TextOnPrimary">#1C0A09</Color>

    <!-- PIN pad -->
    <Color x:Key="PinDotEmpty">#4D2828</Color>
    <Color x:Key="PinDotFilled">#F4A28A</Color>

    <!-- Legacy aliases so framework styles don't break -->
    <Color x:Key="Secondary">#3D2020</Color>
    <Color x:Key="White">#FFFFFF</Color>
    <Color x:Key="Black">#000000</Color>
    <Color x:Key="OffBlack">#1C0A09</Color>
    <Color x:Key="MidnightBlue">#2C1515</Color>
    <Color x:Key="Magenta">#F4A28A</Color>
    <Color x:Key="PrimaryDarkText">#F1E8E6</Color>
    <Color x:Key="SecondaryDarkText">#B8948A</Color>
    <Color x:Key="Gray100">#4D2828</Color>
    <Color x:Key="Gray200">#7A5250</Color>
    <Color x:Key="Gray300">#9A6860</Color>
    <Color x:Key="Gray400">#B8948A</Color>
    <Color x:Key="Gray500">#D4BCB8</Color>
    <Color x:Key="Gray600">#E8D8D4</Color>
    <Color x:Key="Gray900">#F1E8E6</Color>
    <Color x:Key="Gray950">#F8F2F0</Color>

    <SolidColorBrush x:Key="PrimaryBrush"    Color="{StaticResource Primary}"/>
    <SolidColorBrush x:Key="WhiteBrush"      Color="{StaticResource White}"/>
    <SolidColorBrush x:Key="BlackBrush"      Color="{StaticResource Black}"/>
    <SolidColorBrush x:Key="Gray100Brush"    Color="{StaticResource Gray100}"/>
    <SolidColorBrush x:Key="Gray200Brush"    Color="{StaticResource Gray200}"/>
    <SolidColorBrush x:Key="Gray300Brush"    Color="{StaticResource Gray300}"/>
    <SolidColorBrush x:Key="Gray400Brush"    Color="{StaticResource Gray400}"/>
    <SolidColorBrush x:Key="Gray500Brush"    Color="{StaticResource Gray500}"/>
    <SolidColorBrush x:Key="Gray600Brush"    Color="{StaticResource Gray600}"/>
    <SolidColorBrush x:Key="Gray900Brush"    Color="{StaticResource Gray900}"/>
    <SolidColorBrush x:Key="Gray950Brush"    Color="{StaticResource Gray950}"/>

</ResourceDictionary>
