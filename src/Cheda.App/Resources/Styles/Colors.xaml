<?xml version="1.0" encoding="UTF-8" ?>
<ResourceDictionary
    xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
    xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml">

    <!-- Brand — M-Pesa green -->
    <Color x:Key="Primary">#00875A</Color>
    <Color x:Key="PrimaryDark">#005E3F</Color>
    <Color x:Key="PrimaryLight">#003D29</Color>

    <!-- Semantic -->
    <Color x:Key="Danger">#EF4444</Color>
    <Color x:Key="Warning">#F59E0B</Color>
    <Color x:Key="Success">#10B981</Color>

    <!-- Dark surface hierarchy -->
    <Color x:Key="Background">#0F172A</Color>
    <Color x:Key="Surface">#1E293B</Color>
    <Color x:Key="SurfaceVariant">#263447</Color>
    <Color x:Key="Divider">#334155</Color>

    <!-- Text on dark -->
    <Color x:Key="TextPrimary">#F1F5F9</Color>
    <Color x:Key="TextSecondary">#94A3B8</Color>
    <Color x:Key="TextHint">#475569</Color>
    <Color x:Key="TextOnPrimary">#FFFFFF</Color>

    <!-- PIN pad -->
    <Color x:Key="PinDotEmpty">#334155</Color>
    <Color x:Key="PinDotFilled">#00875A</Color>

    <!-- Legacy aliases so framework styles don't break -->
    <Color x:Key="Secondary">#263447</Color>
    <Color x:Key="White">#FFFFFF</Color>
    <Color x:Key="Black">#000000</Color>
    <Color x:Key="OffBlack">#0F172A</Color>
    <Color x:Key="MidnightBlue">#1E293B</Color>
    <Color x:Key="Magenta">#00875A</Color>
    <Color x:Key="PrimaryDarkText">#F1F5F9</Color>
    <Color x:Key="SecondaryDarkText">#94A3B8</Color>
    <Color x:Key="Gray100">#334155</Color>
    <Color x:Key="Gray200">#475569</Color>
    <Color x:Key="Gray300">#64748B</Color>
    <Color x:Key="Gray400">#94A3B8</Color>
    <Color x:Key="Gray500">#CBD5E1</Color>
    <Color x:Key="Gray600">#E2E8F0</Color>
    <Color x:Key="Gray900">#F1F5F9</Color>
    <Color x:Key="Gray950">#F8FAFC</Color>

    <SolidColorBrush x:Key="PrimaryBrush"    Color="{StaticResource Primary}"/>
    <SolidColorBrush x:Key="WhiteBrush"      Color="{StaticResource White}"/>
    <SolidColorBrush x:Key="BlackBrush"      Color="{StaticResource Black}"/>
    <SolidColorBrush x:Key="Gray100Brush"    Color="{StaticResource Gray100}"/>
    <SolidColorBrush x:Key="Gray200Brush"    Color="{StaticResource Gray200}"/>
    <SolidColorBrush x:Key="Gray300Brush"    Color="{StaticResource Gray300}"/>
    <SolidColorBrush x:Key="Gray400Brush"    Color="{StaticResource Gray400}"/>
    <SolidColorBrush x:Key="Gray500Brush"    Color="{StaticResource Gray500}"/>
    <SolidColorBrush x:Key="Gray600Brush"    Color="{StaticResource Gray600}"/>
    <SolidColorBrush x:Key="Gray900Brush"    Color="{StaticResource Gray900}"/>
    <SolidColorBrush x:Key="Gray950Brush"    Color="{StaticResource Gray950}"/>

</ResourceDictionary>
