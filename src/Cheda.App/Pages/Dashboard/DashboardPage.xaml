<?xml version="1.0" encoding="utf-8" ?>
<ContentPage
    xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
    xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
    xmlns:local="clr-namespace:Cheda.App.Pages.Dashboard"
    x:Class="Cheda.App.Pages.Dashboard.DashboardPage"
    Title="Home"
    BackgroundColor="{StaticResource Background}">

    <Grid>
    <RefreshView Command="{Binding RefreshCommand}" IsRefreshing="{Binding IsBusy}">
        <ScrollView BackgroundColor="{StaticResource Background}">
            <VerticalStackLayout x:Name="ContentLayout" Spacing="0" Opacity="0">

                <!-- ── Hero header ─────────────────────────────────────── -->
                <Border BackgroundColor="{StaticResource Surface}"
                        Stroke="Transparent" Padding="20,24,20,20">
                    <VerticalStackLayout Spacing="0">
                        <!-- Brand row -->
                        <Grid ColumnDefinitions="Auto,*,Auto" Margin="0,0,0,20">
                            <Border Grid.Column="0"
                                    WidthRequest="34" HeightRequest="34"
                                    BackgroundColor="{StaticResource Primary}"
                                    StrokeShape="RoundRectangle 9" Stroke="Transparent">
                                <Label Text="₵" FontSize="19" FontAttributes="Bold"
                                       TextColor="White" HorizontalOptions="Center"
                                       VerticalOptions="Center"/>
                            </Border>
                            <Label Grid.Column="1" Text="Cheda"
                                   FontSize="17" FontAttributes="Bold"
                                   TextColor="{StaticResource TextPrimary}"
                                   VerticalOptions="Center" Margin="10,0,0,0"/>
                            <Label Grid.Column="2" Text="{Binding MonthLabel}"
                                   FontSize="11" TextColor="{StaticResource TextHint}"
                                   VerticalOptions="Center"/>
                        </Grid>

                        <!-- Balance label + amount -->
                        <Label Text="M-Pesa Balance"
                               TextColor="{StaticResource TextSecondary}" FontSize="12"/>
                        <Label Text="{Binding Balance, StringFormat='Ksh {0:N2}'}"
                               FontSize="34" FontAttributes="Bold"
                               TextColor="{StaticResource Primary}" Margin="0,4,0,0"/>

                        <!-- Net flow pill -->
                        <Border Padding="12,5" HorizontalOptions="Start" Margin="0,12,0,0"
                                StrokeShape="RoundRectangle 20" StrokeThickness="1"
                                BackgroundColor="{StaticResource SurfaceVariant}"
                                Stroke="{StaticResource Divider}">
                            <Label Text="{Binding NetFlowLabel}"
                                   TextColor="{Binding NetFlowColor}"
                                   FontSize="12" FontAttributes="Bold"/>
                        </Border>
                    </VerticalStackLayout>
                </Border>

                <!-- Divider -->
                <BoxView HeightRequest="1" BackgroundColor="{StaticResource Divider}"/>

                <!-- ── Spent / Received ─────────────────────────────────── -->
                <Grid ColumnDefinitions="*,*">
                    <Border Grid.Column="0" BackgroundColor="{StaticResource Surface}"
                            Padding="16,14" Stroke="Transparent">
                        <VerticalStackLayout Spacing="4">
                            <Label Text="↑  Spent" FontSize="11"
                                   TextColor="{StaticResource TextHint}"/>
                            <Label Text="{Binding SpentThisMonth, StringFormat='Ksh {0:N0}'}"
                                   FontAttributes="Bold" FontSize="17"
                                   TextColor="{StaticResource Danger}"/>
                        </VerticalStackLayout>
                    </Border>
                    <BoxView Grid.Column="0" WidthRequest="1" HorizontalOptions="End"
                             BackgroundColor="{StaticResource Divider}"/>
                    <Border Grid.Column="1" BackgroundColor="{StaticResource Surface}"
                            Padding="16,14" Stroke="Transparent">
                        <VerticalStackLayout Spacing="4">
                            <Label Text="↓  Received" FontSize="11"
                                   TextColor="{StaticResource TextHint}"/>
                            <Label Text="{Binding ReceivedThisMonth, StringFormat='Ksh {0:N0}'}"
                                   FontAttributes="Bold" FontSize="17"
                                   TextColor="{StaticResource Success}"/>
                        </VerticalStackLayout>
                    </Border>
                </Grid>

                <!-- Divider -->
                <BoxView HeightRequest="1" BackgroundColor="{StaticResource Divider}"/>

                <!-- ── Review alert ────────────────────────────────────── -->
                <Border Margin="16,14,16,0" Padding="14,12"
                        BackgroundColor="{StaticResource PrimaryLight}"
                        Stroke="{StaticResource Primary}" StrokeThickness="1"
                        StrokeShape="RoundRectangle 12"
                        IsVisible="{Binding HasReviewItems}">
                    <Border.GestureRecognizers>
                        <TapGestureRecognizer Command="{Binding OpenReviewCommand}"/>
                    </Border.GestureRecognizers>
                    <Grid ColumnDefinitions="Auto,*,Auto" ColumnSpacing="10">
                        <Label Grid.Column="0" Text="🔔" FontSize="18" VerticalOptions="Center"/>
                        <Label Grid.Column="1" VerticalOptions="Center"
                               TextColor="{StaticResource TextPrimary}" FontSize="13"
                               FontAttributes="Bold"
                               Text="{Binding ReviewCount, StringFormat='{0} transactions need categorising'}"/>
                        <Label Grid.Column="2" Text="›" FontSize="22"
                               TextColor="{StaticResource Primary}" VerticalOptions="Center"/>
                    </Grid>
                </Border>

                <!-- ── Recent transactions ─────────────────────────────── -->
                <Grid ColumnDefinitions="*,Auto" Margin="16,18,16,8">
                    <Label Grid.Column="0" Text="Recent Transactions"
                           FontAttributes="Bold" FontSize="16"
                           TextColor="{StaticResource TextPrimary}"/>
                    <Label Grid.Column="1" Text="View All"
                           FontSize="13" TextColor="{StaticResource Primary}"
                           VerticalOptions="Center">
                        <Label.GestureRecognizers>
                            <TapGestureRecognizer Command="{Binding ViewAllCommand}"/>
                        </Label.GestureRecognizers>
                    </Label>
                </Grid>

                <CollectionView ItemsSource="{Binding Recent}">
                    <CollectionView.ItemTemplate>
                        <DataTemplate x:DataType="local:RecentRow">
                            <Border BackgroundColor="{StaticResource Surface}" Margin="12,4"
                                    Stroke="Transparent" StrokeShape="RoundRectangle 14">
                                <Border.GestureRecognizers>
                                    <TapGestureRecognizer
                                        Command="{Binding Source={RelativeSource AncestorType={x:Type ContentPage}}, Path=BindingContext.OpenDetailCommand}"
                                        CommandParameter="{Binding .}"/>
                                </Border.GestureRecognizers>
                                <Grid ColumnDefinitions="4,Auto,*,Auto" ColumnSpacing="0">
                                    <!-- Accent bar -->
                                    <BoxView Grid.Column="0"
                                             BackgroundColor="{Binding AccentColor}"
                                             CornerRadius="14,0,14,0"/>
                                    <!-- Type icon -->
                                    <Border Grid.Column="1"
                                            WidthRequest="38" HeightRequest="38"
                                            BackgroundColor="{StaticResource SurfaceVariant}"
                                            Stroke="Transparent" StrokeShape="RoundRectangle 19"
                                            Margin="10,10,0,10" VerticalOptions="Center">
                                        <Label Text="{Binding TypeIcon}" FontSize="17"
                                               HorizontalOptions="Center" VerticalOptions="Center"/>
                                    </Border>
                                    <!-- Type + counterparty -->
                                    <VerticalStackLayout Grid.Column="2"
                                                         Margin="10,10,4,10" Spacing="2"
                                                         VerticalOptions="Center">
                                        <Label Text="{Binding TypeLabel}"
                                               FontAttributes="Bold" FontSize="13"
                                               TextColor="{StaticResource TextPrimary}"
                                               MaxLines="1" LineBreakMode="TailTruncation"/>
                                        <Label Text="{Binding Counterparty}"
                                               FontSize="11" TextColor="{StaticResource Primary}"
                                               MaxLines="1" LineBreakMode="TailTruncation"/>
                                        <Label Text="{Binding Category}"
                                               FontSize="10" TextColor="{StaticResource TextHint}"/>
                                    </VerticalStackLayout>
                                    <!-- Amount + date -->
                                    <VerticalStackLayout Grid.Column="3"
                                                         HorizontalOptions="End"
                                                         Spacing="2" VerticalOptions="Center"
                                                         Margin="0,0,12,0">
                                        <Label Text="{Binding AmountLabel}"
                                               FontAttributes="Bold" FontSize="13"
                                               TextColor="{Binding AmountColor}"
                                               HorizontalOptions="End"/>
                                        <Label Text="{Binding TimeLabel}" FontSize="10"
                                               TextColor="{StaticResource TextHint}"
                                               HorizontalOptions="End"/>
                                    </VerticalStackLayout>
                                </Grid>
                            </Border>
                        </DataTemplate>
                    </CollectionView.ItemTemplate>
                    <CollectionView.EmptyView>
                        <VerticalStackLayout HorizontalOptions="Center"
                                             Margin="0,40" Spacing="8">
                            <Label Text="📭" FontSize="48" HorizontalOptions="Center"/>
                            <Label Text="No transactions yet."
                                   FontSize="15" TextColor="{StaticResource TextSecondary}"
                                   HorizontalOptions="Center"/>
                            <Label Text="Go to Settings → Import SMS to get started."
                                   FontSize="12" TextColor="{StaticResource TextHint}"
                                   HorizontalOptions="Center"/>
                        </VerticalStackLayout>
                    </CollectionView.EmptyView>
                </CollectionView>

                <BoxView HeightRequest="24" Color="Transparent"/>
            </VerticalStackLayout>
        </ScrollView>
    </RefreshView>

    <!-- First-load overlay -->
    <Grid x:Name="LoadingOverlay" BackgroundColor="{StaticResource Background}">
        <VerticalStackLayout VerticalOptions="Center" HorizontalOptions="Center" Spacing="20">
            <Border WidthRequest="64" HeightRequest="64"
                    BackgroundColor="{StaticResource Primary}"
                    StrokeShape="RoundRectangle 18" Stroke="Transparent">
                <Label Text="₵" FontSize="38" FontAttributes="Bold"
                       TextColor="White" HorizontalOptions="Center"
                       VerticalOptions="Center"/>
            </Border>
            <ActivityIndicator IsRunning="True" Color="{StaticResource Primary}"
                               WidthRequest="32" HeightRequest="32"/>
        </VerticalStackLayout>
    </Grid>
    </Grid>

</ContentPage>
