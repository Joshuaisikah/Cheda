<?xml version="1.0" encoding="utf-8" ?>
<ContentPage
    xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
    xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
    x:Class="Cheda.App.Pages.Transactions.TransactionsPage"
    Title="Transactions"
    BackgroundColor="{StaticResource Background}">

    <Grid RowDefinitions="Auto,Auto,*">

        <!-- Search bar -->
        <SearchBar Grid.Row="0" Placeholder="Search by merchant or category"
                   Text="{Binding SearchText}" Margin="8,8,8,4"/>

        <!-- Filter chips -->
        <CollectionView Grid.Row="1" ItemsSource="{Binding Filters}" HeightRequest="44"
                        SelectionMode="Single" Margin="8,0">
            <CollectionView.ItemsLayout>
                <LinearItemsLayout Orientation="Horizontal" ItemSpacing="6"/>
            </CollectionView.ItemsLayout>
            <CollectionView.ItemTemplate>
                <DataTemplate x:DataType="x:String">
                    <Border Padding="12,6" StrokeShape="RoundRectangle 20">
                        <Border.GestureRecognizers>
                            <TapGestureRecognizer Command="{Binding Source={RelativeSource AncestorType={x:Type ContentPage}}, Path=BindingContext.SetFilterCommand}"
                                                  CommandParameter="{Binding .}"/>
                        </Border.GestureRecognizers>
                        <Label Text="{Binding .}" TextColor="{StaticResource Primary}" FontSize="13"/>
                    </Border>
                </DataTemplate>
            </CollectionView.ItemTemplate>
        </CollectionView>

        <!-- Transaction list -->
        <RefreshView Grid.Row="2" Command="{Binding RefreshCommand}" IsRefreshing="{Binding IsBusy}">
            <CollectionView ItemsSource="{Binding Transactions}">
                <CollectionView.ItemTemplate>
                    <DataTemplate>
                        <Border Style="{StaticResource CardStyle}" Margin="8,4">
                            <Border.GestureRecognizers>
                                <TapGestureRecognizer
                                    Command="{Binding Source={RelativeSource AncestorType={x:Type ContentPage}}, Path=BindingContext.OpenEditCommand}"
                                    CommandParameter="{Binding .}"/>
                            </Border.GestureRecognizers>
                            <Grid ColumnDefinitions="*,Auto" Padding="16,12">
                                <VerticalStackLayout Grid.Column="0" Spacing="2">
                                    <Label Text="{Binding Counterparty, FallbackValue='—'}"
                                           FontAttributes="Bold" TextColor="{StaticResource TextPrimary}"/>
                                    <Label Text="{Binding Category}" FontSize="12"
                                           TextColor="{StaticResource TextSecondary}"/>
                                    <Label Text="{Binding Timestamp, StringFormat='{0:dd MMM yyyy  HH:mm}'}"
                                           FontSize="11" TextColor="{StaticResource TextHint}"/>
                                </VerticalStackLayout>
                                <Label Grid.Column="1"
                                       Text="{Binding Amount, StringFormat='Ksh {0:N0}'}"
                                       FontAttributes="Bold" TextColor="{StaticResource TextPrimary}"
                                       VerticalOptions="Center"/>
                            </Grid>
                        </Border>
                    </DataTemplate>
                </CollectionView.ItemTemplate>
                <CollectionView.EmptyView>
                    <Label Text="No transactions found." TextColor="{StaticResource TextHint}"
                           HorizontalOptions="Center" Margin="0,48"/>
                </CollectionView.EmptyView>
            </CollectionView>
        </RefreshView>

    </Grid>

</ContentPage>
