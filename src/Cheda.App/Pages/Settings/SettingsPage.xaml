<?xml version="1.0" encoding="utf-8" ?>
<ContentPage
    xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
    xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
    x:Class="Cheda.App.Pages.Settings.SettingsPage"
    NavigationPage.HasNavigationBar="False"
    BackgroundColor="{StaticResource Background}">

    <Grid>
    <ScrollView BackgroundColor="{StaticResource Background}">
        <VerticalStackLayout x:Name="ContentLayout" Padding="16,52,16,32" Spacing="0" Opacity="0">

            <!-- Title -->
            <Label Text="Settings"
                   FontSize="34" FontAttributes="Bold"
                   TextColor="{StaticResource Primary}"
                   Margin="4,0,0,24"/>

            <!-- ── PREFERENCES ─────────────────────────────────────── -->
            <Label Text="PREFERENCES" FontSize="11" FontAttributes="Bold"
                   CharacterSpacing="1.5"
                   TextColor="{StaticResource TextSecondary}"
                   Margin="4,0,0,10"/>

            <Border Style="{StaticResource CardStyle}" Margin="0,0,0,20">
                <VerticalStackLayout Padding="16" Spacing="12">
                    <Grid ColumnDefinitions="*,Auto">
                        <VerticalStackLayout Grid.Column="0" Spacing="2">
                            <Label Text="Biometric Lock" FontAttributes="Bold" FontSize="15"
                                   TextColor="{StaticResource TextPrimary}"/>
                            <Label Text="Lock app after inactivity" FontSize="12"
                                   TextColor="{StaticResource TextSecondary}"/>
                        </VerticalStackLayout>
                        <Switch Grid.Column="1" IsToggled="{Binding BiometricEnabled}"
                                OnColor="{StaticResource Primary}"
                                VerticalOptions="Center"/>
                    </Grid>
                    <Label Text="{Binding LockAfterLabel}" FontSize="12"
                           TextColor="{StaticResource TextSecondary}"
                           IsVisible="{Binding BiometricEnabled}"/>
                    <HorizontalStackLayout Spacing="8" IsVisible="{Binding BiometricEnabled}">
                        <Border Padding="12,7" StrokeShape="RoundRectangle 10"
                                BackgroundColor="{Binding LockDelay0Bg}"
                                Stroke="{StaticResource Divider}" StrokeThickness="1">
                            <Border.GestureRecognizers>
                                <TapGestureRecognizer Command="{Binding SetLockDelayCommand}" CommandParameter="0"/>
                            </Border.GestureRecognizers>
                            <Label Text="Immediately" FontSize="12" TextColor="{Binding LockDelay0Fg}"/>
                        </Border>
                        <Border Padding="12,7" StrokeShape="RoundRectangle 10"
                                BackgroundColor="{Binding LockDelay1Bg}"
                                Stroke="{StaticResource Divider}" StrokeThickness="1">
                            <Border.GestureRecognizers>
                                <TapGestureRecognizer Command="{Binding SetLockDelayCommand}" CommandParameter="1"/>
                            </Border.GestureRecognizers>
                            <Label Text="1 minute" FontSize="12" TextColor="{Binding LockDelay1Fg}"/>
                        </Border>
                        <Border Padding="12,7" StrokeShape="RoundRectangle 10"
                                BackgroundColor="{Binding LockDelay5Bg}"
                                Stroke="{StaticResource Divider}" StrokeThickness="1">
                            <Border.GestureRecognizers>
                                <TapGestureRecognizer Command="{Binding SetLockDelayCommand}" CommandParameter="5"/>
                            </Border.GestureRecognizers>
                            <Label Text="5 minutes" FontSize="12" TextColor="{Binding LockDelay5Fg}"/>
                        </Border>
                        <Border Padding="12,7" StrokeShape="RoundRectangle 10"
                                BackgroundColor="{Binding LockDelay15Bg}"
                                Stroke="{StaticResource Divider}" StrokeThickness="1">
                            <Border.GestureRecognizers>
                                <TapGestureRecognizer Command="{Binding SetLockDelayCommand}" CommandParameter="15"/>
                            </Border.GestureRecognizers>
                            <Label Text="15 minutes" FontSize="12" TextColor="{Binding LockDelay15Fg}"/>
                        </Border>
                    </HorizontalStackLayout>
                </VerticalStackLayout>
            </Border>

            <!-- ── DATA ───────────────────────────────────────────── -->
            <Label Text="DATA" FontSize="11" FontAttributes="Bold"
                   CharacterSpacing="1.5"
                   TextColor="{StaticResource TextSecondary}"
                   Margin="4,0,0,10"/>
            <Border Style="{StaticResource CardStyle}" Margin="0,0,0,20">
                <VerticalStackLayout Padding="16" Spacing="14">
                    <Grid ColumnDefinitions="Auto,*">
                        <Border Grid.Column="0" WidthRequest="38" HeightRequest="38"
                                BackgroundColor="{StaticResource PrimaryLight}"
                                StrokeShape="RoundRectangle 10" Stroke="Transparent">
                            <Label Text="📱" FontSize="18" HorizontalOptions="Center"
                                   VerticalOptions="Center"/>
                        </Border>
                        <VerticalStackLayout Grid.Column="1" Margin="12,0,0,0" Spacing="2"
                                             VerticalOptions="Center">
                            <Label Text="Scan my messages" FontAttributes="Bold" FontSize="14"
                                   TextColor="{StaticResource TextPrimary}"/>
                            <Label Text="Reads M-Pesa SMS directly from your phone"
                                   FontSize="12" TextColor="{StaticResource TextSecondary}"/>
                        </VerticalStackLayout>
                    </Grid>
                    <Button Text="📲  Scan Messages Now" Command="{Binding ScanSmsCommand}"
                            Style="{StaticResource PrimaryButtonStyle}"
                            IsEnabled="{Binding IsBusy, Converter={StaticResource InvertBoolConverter}}"/>
                    <BoxView HeightRequest="1" BackgroundColor="{StaticResource Divider}"/>
                    <Grid ColumnDefinitions="Auto,*">
                        <Border Grid.Column="0" WidthRequest="38" HeightRequest="38"
                                BackgroundColor="{StaticResource SurfaceVariant}"
                                StrokeShape="RoundRectangle 10" Stroke="Transparent">
                            <Label Text="📂" FontSize="18" HorizontalOptions="Center"
                                   VerticalOptions="Center"/>
                        </Border>
                        <VerticalStackLayout Grid.Column="1" Margin="12,0,0,0" Spacing="2"
                                             VerticalOptions="Center">
                            <Label Text="Import from backup file" FontAttributes="Bold" FontSize="13"
                                   TextColor="{StaticResource TextPrimary}"/>
                            <Label Text="XML from SMS Backup &amp; Restore app"
                                   FontSize="12" TextColor="{StaticResource TextSecondary}"/>
                        </VerticalStackLayout>
                    </Grid>
                    <Button Text="Choose XML File" Command="{Binding ImportXmlCommand}"
                            Style="{StaticResource SecondaryButtonStyle}"
                            IsEnabled="{Binding IsBusy, Converter={StaticResource InvertBoolConverter}}"/>
                    <BoxView HeightRequest="1" BackgroundColor="{StaticResource Divider}"/>
                    <Grid ColumnDefinitions="Auto,*">
                        <Border Grid.Column="0" WidthRequest="38" HeightRequest="38"
                                BackgroundColor="{StaticResource SurfaceVariant}"
                                StrokeShape="RoundRectangle 10" Stroke="Transparent">
                            <Label Text="🔄" FontSize="18" HorizontalOptions="Center"
                                   VerticalOptions="Center"/>
                        </Border>
                        <VerticalStackLayout Grid.Column="1" Margin="12,0,0,0" Spacing="2"
                                             VerticalOptions="Center">
                            <Label Text="Re-detect SIM transfers" FontAttributes="Bold" FontSize="13"
                                   TextColor="{StaticResource TextPrimary}"/>
                            <Label Text="Finds inter-SIM transfers in existing history"
                                   FontSize="12" TextColor="{StaticResource TextSecondary}"/>
                        </VerticalStackLayout>
                    </Grid>
                    <Button Text="Re-detect Now" Command="{Binding RedetectSimTransfersCommand}"
                            Style="{StaticResource SecondaryButtonStyle}"
                            IsEnabled="{Binding IsBusy, Converter={StaticResource InvertBoolConverter}}"/>
                    <Label Text="{Binding ImportResult}"
                           TextColor="{StaticResource Success}"
                           IsVisible="{Binding ImportResult, Converter={StaticResource NullToBoolConverter}}"
                           FontSize="13" Margin="4,0,0,0"/>
                </VerticalStackLayout>
            </Border>

            <!-- ── SECURITY ───────────────────────────────────────── -->
            <Label Text="SECURITY" FontSize="11" FontAttributes="Bold"
                   CharacterSpacing="1.5"
                   TextColor="{StaticResource TextSecondary}"
                   Margin="4,0,0,10"/>
            <Border Style="{StaticResource CardStyle}" Margin="0,0,0,10">
                <VerticalStackLayout Padding="16" Spacing="12">
                    <Label Text="Change PIN" FontAttributes="Bold" FontSize="14"
                           TextColor="{StaticResource TextPrimary}"/>
                    <Border BackgroundColor="{StaticResource SurfaceVariant}"
                            Stroke="{StaticResource Divider}" StrokeShape="RoundRectangle 8"
                            StrokeThickness="1" Padding="12,0">
                        <Entry Placeholder="Current PIN" IsPassword="True" Keyboard="Numeric"
                               Text="{Binding CurrentPin}" MaxLength="6"
                               PlaceholderColor="{StaticResource TextHint}"
                               TextColor="{StaticResource TextPrimary}"
                               BackgroundColor="Transparent" HeightRequest="44"/>
                    </Border>
                    <Border BackgroundColor="{StaticResource SurfaceVariant}"
                            Stroke="{StaticResource Divider}" StrokeShape="RoundRectangle 8"
                            StrokeThickness="1" Padding="12,0">
                        <Entry Placeholder="New PIN (4–6 digits)" IsPassword="True" Keyboard="Numeric"
                               Text="{Binding NewPin}" MaxLength="6"
                               PlaceholderColor="{StaticResource TextHint}"
                               TextColor="{StaticResource TextPrimary}"
                               BackgroundColor="Transparent" HeightRequest="44"/>
                    </Border>
                    <Border BackgroundColor="{StaticResource SurfaceVariant}"
                            Stroke="{StaticResource Divider}" StrokeShape="RoundRectangle 8"
                            StrokeThickness="1" Padding="12,0">
                        <Entry Placeholder="Confirm new PIN" IsPassword="True" Keyboard="Numeric"
                               Text="{Binding NewPinConfirm}" MaxLength="6"
                               PlaceholderColor="{StaticResource TextHint}"
                               TextColor="{StaticResource TextPrimary}"
                               BackgroundColor="Transparent" HeightRequest="44"/>
                    </Border>
                    <Label Text="{Binding PinChangeResult}" FontSize="13"
                           IsVisible="{Binding PinChangeResult, Converter={StaticResource NullToBoolConverter}}"
                           TextColor="{StaticResource Success}" Margin="4,0,0,0"/>
                    <Button Text="Change PIN" Command="{Binding ChangePinCommand}"
                            Style="{StaticResource SecondaryButtonStyle}"/>
                </VerticalStackLayout>
            </Border>
            <Button Text="🔒  Lock App Now" Command="{Binding LockCommand}"
                    Style="{StaticResource DangerButtonStyle}"
                    Margin="0,0,0,20"/>

            <!-- ── ABOUT ──────────────────────────────────────────── -->
            <Label Text="ABOUT" FontSize="11" FontAttributes="Bold"
                   CharacterSpacing="1.5"
                   TextColor="{StaticResource TextSecondary}"
                   Margin="4,0,0,10"/>

            <Border Style="{StaticResource CardStyle}" Margin="0,0,0,10">
                <VerticalStackLayout Padding="16" Spacing="10">
                    <Grid ColumnDefinitions="Auto,*" ColumnSpacing="12">
                        <Border Grid.Column="0" WidthRequest="44" HeightRequest="44"
                                BackgroundColor="{StaticResource Primary}"
                                StrokeShape="RoundRectangle 12" Stroke="Transparent">
                            <Label Text="ℹ" FontSize="22" FontAttributes="Bold"
                                   TextColor="{StaticResource TextOnPrimary}"
                                   HorizontalOptions="Center" VerticalOptions="Center"/>
                        </Border>
                        <VerticalStackLayout Grid.Column="1" VerticalOptions="Center" Spacing="2">
                            <Label Text="Cheda" FontAttributes="Bold" FontSize="16"
                                   TextColor="{StaticResource TextPrimary}"/>
                            <Label Text="Version 1.0" FontSize="12"
                                   TextColor="{StaticResource TextSecondary}"/>
                        </VerticalStackLayout>
                    </Grid>
                    <Label Text="Privacy-first M-Pesa tracker. Your transactions stay on your device."
                           FontSize="12" TextColor="{StaticResource TextSecondary}"
                           LineBreakMode="WordWrap"/>
                    <BoxView HeightRequest="1" BackgroundColor="{StaticResource Divider}"/>
                    <Label Text="• Transaction data is stored locally and never shared"
                           FontSize="12" TextColor="{StaticResource TextSecondary}"/>
                    <Label Text="• SMS messages are read and processed on-device"
                           FontSize="12" TextColor="{StaticResource TextSecondary}"/>
                    <Label Text="• You have full control of your data"
                           FontSize="12" TextColor="{StaticResource TextSecondary}"/>
                </VerticalStackLayout>
            </Border>

            <Border Style="{StaticResource CardStyle}" Margin="0,0,0,10">
                <Grid ColumnDefinitions="Auto,*,Auto" Padding="14,14" ColumnSpacing="12">
                    <Border Grid.Column="0" WidthRequest="44" HeightRequest="44"
                            BackgroundColor="{StaticResource SurfaceVariant}"
                            StrokeShape="RoundRectangle 22" Stroke="Transparent">
                        <Label Text="📲" FontSize="20"
                               HorizontalOptions="Center" VerticalOptions="Center"/>
                    </Border>
                    <VerticalStackLayout Grid.Column="1" VerticalOptions="Center" Spacing="2">
                        <Label Text="Invite a Friend" FontAttributes="Bold" FontSize="14"
                               TextColor="{StaticResource TextPrimary}"/>
                        <Label Text="Share Cheda with someone who uses M-Pesa"
                               FontSize="12" TextColor="{StaticResource TextSecondary}"/>
                    </VerticalStackLayout>
                    <Label Grid.Column="2" Text="→" FontSize="18"
                           TextColor="{StaticResource TextSecondary}"
                           VerticalOptions="Center">
                        <Label.GestureRecognizers>
                            <TapGestureRecognizer Command="{Binding InviteFriendCommand}"/>
                        </Label.GestureRecognizers>
                    </Label>
                </Grid>
            </Border>

            <Border Style="{StaticResource CardStyle}" Margin="0,0,0,32">
                <Grid ColumnDefinitions="Auto,*,Auto" Padding="14,14" ColumnSpacing="12">
                    <Border Grid.Column="0" WidthRequest="44" HeightRequest="44"
                            BackgroundColor="#4D1515"
                            StrokeShape="RoundRectangle 22" Stroke="Transparent">
                        <Label Text="🗑️" FontSize="20"
                               HorizontalOptions="Center" VerticalOptions="Center"/>
                    </Border>
                    <VerticalStackLayout Grid.Column="1" VerticalOptions="Center" Spacing="2">
                        <Label Text="Clear History" FontAttributes="Bold" FontSize="14"
                               TextColor="{StaticResource Danger}"/>
                        <Label Text="Permanently delete all transaction data"
                               FontSize="12" TextColor="{StaticResource TextSecondary}"/>
                    </VerticalStackLayout>
                    <Label Grid.Column="2" Text="→" FontSize="18"
                           TextColor="{StaticResource Danger}"
                           VerticalOptions="Center">
                        <Label.GestureRecognizers>
                            <TapGestureRecognizer Command="{Binding ClearHistoryCommand}"/>
                        </Label.GestureRecognizers>
                    </Label>
                </Grid>
            </Border>

        </VerticalStackLayout>
    </ScrollView>

    <Grid x:Name="LoadingOverlay" BackgroundColor="{StaticResource Background}" IsVisible="False"/>
    </Grid>

</ContentPage>
