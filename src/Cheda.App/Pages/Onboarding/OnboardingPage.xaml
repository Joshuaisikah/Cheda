<?xml version="1.0" encoding="utf-8" ?>
<ContentPage
    xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
    xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
    x:Class="Cheda.App.Pages.Onboarding.OnboardingPage"
    NavigationPage.HasNavigationBar="False"
    BackgroundColor="{StaticResource Background}">

    <Grid RowDefinitions="Auto,*,Auto" Padding="32,56,32,40">

        <!-- Brand header -->
        <VerticalStackLayout Grid.Row="0" Spacing="8" HorizontalOptions="Center" Margin="0,0,0,40">
            <Border WidthRequest="64" HeightRequest="64"
                    BackgroundColor="{StaticResource Primary}"
                    StrokeShape="RoundRectangle 18" Stroke="Transparent"
                    HorizontalOptions="Center">
                <Label Text="₵" FontSize="32" FontAttributes="Bold"
                       TextColor="White" HorizontalOptions="Center" VerticalOptions="Center"/>
            </Border>
            <Label Text="CHEDA" FontSize="13" FontAttributes="Bold" CharacterSpacing="4"
                   TextColor="{StaticResource TextSecondary}" HorizontalOptions="Center"/>
        </VerticalStackLayout>

        <!-- Step content -->
        <Grid Grid.Row="1">

            <!-- Step 0: Welcome -->
            <VerticalStackLayout Spacing="20" VerticalOptions="Center"
                                 IsVisible="{Binding Step, Converter={StaticResource EqualConverter}, ConverterParameter=0}">
                <Label Text="Your private M-Pesa assistant"
                       FontSize="26" FontAttributes="Bold"
                       TextColor="{StaticResource TextPrimary}"
                       HorizontalTextAlignment="Center"/>
                <Label Text="Track spending, budgets, and bills. All data lives on your phone — no cloud, no ads, no tracking."
                       FontSize="15" LineHeight="1.5"
                       TextColor="{StaticResource TextSecondary}"
                       HorizontalTextAlignment="Center"/>
                <BoxView HeightRequest="1" BackgroundColor="{StaticResource Divider}" Margin="0,12"/>
                <VerticalStackLayout Spacing="12">
                    <Label Text="🔒  End-to-end encrypted on device" TextColor="{StaticResource TextSecondary}" FontSize="14"/>
                    <Label Text="📊  Auto-categorises M-Pesa transactions" TextColor="{StaticResource TextSecondary}" FontSize="14"/>
                    <Label Text="🔔  Bill reminders and budget alerts" TextColor="{StaticResource TextSecondary}" FontSize="14"/>
                </VerticalStackLayout>
            </VerticalStackLayout>

            <!-- Step 1: Set PIN -->
            <VerticalStackLayout Spacing="16" VerticalOptions="Center"
                                 IsVisible="{Binding Step, Converter={StaticResource EqualConverter}, ConverterParameter=1}">
                <Label Text="Create a PIN" FontSize="24" FontAttributes="Bold" TextColor="{StaticResource TextPrimary}"/>
                <Label Text="You'll use this PIN every time you open Cheda." TextColor="{StaticResource TextSecondary}" FontSize="14"/>
                <Border Style="{StaticResource CardStyle}" Margin="0,8,0,0">
                    <VerticalStackLayout Padding="16" Spacing="12">
                        <Entry Placeholder="PIN (4–6 digits)" IsPassword="True" Keyboard="Numeric"
                               Text="{Binding Pin}" MaxLength="6"
                               PlaceholderColor="{StaticResource TextHint}"
                               TextColor="{StaticResource TextPrimary}"
                               BackgroundColor="Transparent"/>
                        <BoxView HeightRequest="1" BackgroundColor="{StaticResource Divider}"/>
                        <Entry Placeholder="Confirm PIN" IsPassword="True" Keyboard="Numeric"
                               Text="{Binding PinConfirm}" MaxLength="6"
                               PlaceholderColor="{StaticResource TextHint}"
                               TextColor="{StaticResource TextPrimary}"
                               BackgroundColor="Transparent"/>
                    </VerticalStackLayout>
                </Border>
                <Label Text="{Binding PinError}" TextColor="{StaticResource Danger}" FontSize="13"
                       IsVisible="{Binding PinError, Converter={StaticResource NullToBoolConverter}}"/>
            </VerticalStackLayout>

            <!-- Step 2: SMS Permission -->
            <VerticalStackLayout Spacing="16" VerticalOptions="Center"
                                 IsVisible="{Binding Step, Converter={StaticResource EqualConverter}, ConverterParameter=2}">
                <Label Text="Allow SMS access" FontSize="24" FontAttributes="Bold" TextColor="{StaticResource TextPrimary}"/>
                <Label Text="Cheda reads M-Pesa confirmation messages to categorise your transactions automatically. Your messages never leave your phone."
                       FontSize="14" LineHeight="1.5" TextColor="{StaticResource TextSecondary}"/>
                <Border Style="{StaticResource CardStyle}" Margin="0,8,0,0"
                        BackgroundColor="{StaticResource PrimaryLight}">
                    <VerticalStackLayout Padding="16" Spacing="6">
                        <Label Text="Only reads messages from MPESA" FontSize="13" TextColor="{StaticResource TextSecondary}"/>
                        <Label Text="Never reads OTPs or personal messages" FontSize="13" TextColor="{StaticResource TextSecondary}"/>
                        <Label Text="No data ever sent to any server" FontSize="13" TextColor="{StaticResource TextSecondary}"/>
                    </VerticalStackLayout>
                </Border>
                <Button Text="Grant Permission" Command="{Binding RequestSmsPermissionCommand}"
                        Style="{StaticResource SecondaryButtonStyle}" Margin="0,8,0,0"
                        IsVisible="{Binding SmsGranted, Converter={StaticResource InvertBoolConverter}}"/>
                <HorizontalStackLayout Spacing="8" HorizontalOptions="Center"
                                       IsVisible="{Binding SmsGranted}">
                    <Label Text="✓" TextColor="{StaticResource Success}" FontSize="16" FontAttributes="Bold"/>
                    <Label Text="Permission granted" TextColor="{StaticResource Success}" FontSize="14"/>
                </HorizontalStackLayout>
            </VerticalStackLayout>

        </Grid>

        <!-- Bottom CTA -->
        <Button Grid.Row="2" Command="{Binding NextCommand}"
                Style="{StaticResource PrimaryButtonStyle}"
                Text="{Binding ButtonLabel}"/>

    </Grid>

</ContentPage>
