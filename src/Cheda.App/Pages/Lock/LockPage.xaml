<?xml version="1.0" encoding="utf-8" ?>
<ContentPage
    xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
    xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
    x:Class="Cheda.App.Pages.Lock.LockPage"
    NavigationPage.HasNavigationBar="False"
    BackgroundColor="#000000">

    <ContentPage.Resources>
        <!-- Matrix-themed numpad buttons -->
        <Style x:Key="MatrixNumPad" TargetType="Button">
            <Setter Property="BackgroundColor"  Value="#0B1A0B"/>
            <Setter Property="TextColor"        Value="#00FF41"/>
            <Setter Property="FontSize"         Value="22"/>
            <Setter Property="FontAttributes"   Value="Bold"/>
            <Setter Property="CornerRadius"     Value="40"/>
            <Setter Property="HeightRequest"    Value="76"/>
            <Setter Property="WidthRequest"     Value="76"/>
            <Setter Property="BorderColor"      Value="#1A4A1A"/>
            <Setter Property="BorderWidth"      Value="1"/>
        </Style>
    </ContentPage.Resources>

    <Grid BackgroundColor="#000000">

        <!-- Layer 0: Matrix rain background (full-screen, non-interactive) -->
        <GraphicsView x:Name="MatrixView" InputTransparent="True"/>

        <!-- Layer 1: Content overlaid on rain -->
        <Grid RowDefinitions="Auto,*,Auto" Padding="28,56,28,40">

            <!-- ══ Row 0: Header — always visible (matrix text + logo) ══ -->
            <VerticalStackLayout Grid.Row="0" Spacing="0">

                <!-- Terminal typewriter lines -->
                <Label x:Name="MatrixLine1"
                       FontFamily="monospace" FontSize="13"
                       TextColor="#00FF41" Opacity="0" Margin="0,0,0,3"
                       CharacterSpacing="0.3"/>
                <Label x:Name="MatrixLine2"
                       FontFamily="monospace" FontSize="13"
                       TextColor="#00CC33" Opacity="0" Margin="0,0,0,3"
                       CharacterSpacing="0.3"/>
                <Label x:Name="MatrixLine3"
                       FontFamily="monospace" FontSize="13"
                       TextColor="#00882A" Opacity="0" Margin="0,0,0,18"
                       CharacterSpacing="0.3"/>

                <!-- Logo row -->
                <HorizontalStackLayout HorizontalOptions="Center" Spacing="14">

                    <!-- Neon ₵ card -->
                    <Border WidthRequest="60" HeightRequest="60"
                            BackgroundColor="#050F05"
                            StrokeShape="RoundRectangle 16"
                            Stroke="#00FF41" StrokeThickness="1.5">
                        <Label Text="₵" FontSize="32" FontAttributes="Bold"
                               TextColor="#00FF41"
                               HorizontalOptions="Center" VerticalOptions="Center"/>
                    </Border>

                    <!-- App name / tagline -->
                    <VerticalStackLayout VerticalOptions="Center" Spacing="3">
                        <Label Text="CHEDA"
                               FontSize="20" FontAttributes="Bold"
                               CharacterSpacing="6"
                               TextColor="#00FF41"/>
                        <Label Text="FINANCIAL.SYSTEM.v1.0"
                               FontSize="8" CharacterSpacing="1.5"
                               TextColor="#1A5C1A"/>
                    </VerticalStackLayout>

                </HorizontalStackLayout>

                <!-- Circuit-trace divider -->
                <BoxView HeightRequest="1" Margin="0,14,0,0"
                         BackgroundColor="#00FF41" Opacity="0.18"/>

            </VerticalStackLayout>

            <!-- ══ Row 1: Spacer ══ -->

            <!-- ══ Row 2: State-specific lock UI ══ -->
            <Grid Grid.Row="2">

                <!-- ── WAITING: biometric auto-fires ── -->
                <VerticalStackLayout IsVisible="{Binding IsWaiting}"
                                     Spacing="16" HorizontalOptions="Center">
                    <VerticalStackLayout.GestureRecognizers>
                        <TapGestureRecognizer Command="{Binding SwitchToBiometricCommand}"/>
                    </VerticalStackLayout.GestureRecognizers>

                    <!-- Spinner with pulsing ₵ -->
                    <Grid WidthRequest="64" HeightRequest="64" HorizontalOptions="Center">
                        <ActivityIndicator IsRunning="True" Color="#00FF41"
                                           WidthRequest="64" HeightRequest="64"
                                           HorizontalOptions="Center"
                                           VerticalOptions="Center"/>
                        <Label x:Name="LockCurrencyLabel"
                               Text="₵" FontSize="24" FontAttributes="Bold"
                               TextColor="#00FF41"
                               HorizontalOptions="Center" VerticalOptions="Center"/>
                    </Grid>

                    <Label Text="SCANNING BIOMETRICS..."
                           FontFamily="monospace" FontSize="10"
                           TextColor="#1A6A1A" CharacterSpacing="2"
                           HorizontalOptions="Center"/>

                    <Label Text="> USE PIN INSTEAD _"
                           FontFamily="monospace" FontSize="14" FontAttributes="Bold"
                           TextColor="#00FF41" HorizontalOptions="Center">
                        <Label.GestureRecognizers>
                            <TapGestureRecognizer Command="{Binding SwitchToPinCommand}"/>
                        </Label.GestureRecognizers>
                    </Label>
                </VerticalStackLayout>

                <!-- ── FINGERPRINT RETRY ── -->
                <VerticalStackLayout IsVisible="{Binding ShowingFingerprintRetry}"
                                     Spacing="18" HorizontalOptions="Center">

                    <!-- Neon fingerprint ring -->
                    <Grid HorizontalOptions="Center" WidthRequest="120" HeightRequest="120">
                        <Ellipse WidthRequest="120" HeightRequest="120"
                                 Stroke="#00FF41" StrokeThickness="1"
                                 Fill="Transparent" Opacity="0.25"/>
                        <Border WidthRequest="92" HeightRequest="92"
                                BackgroundColor="#050F05"
                                Stroke="#00FF41" StrokeThickness="2"
                                StrokeShape="RoundRectangle 46"
                                HorizontalOptions="Center" VerticalOptions="Center">
                            <Border.GestureRecognizers>
                                <TapGestureRecognizer Command="{Binding SwitchToBiometricCommand}"/>
                            </Border.GestureRecognizers>
                            <Image Source="fingerprint.svg"
                                   WidthRequest="48" HeightRequest="48"
                                   HorizontalOptions="Center" VerticalOptions="Center"/>
                        </Border>
                    </Grid>

                    <Label Text="BIOMETRIC AUTH REQUIRED"
                           FontFamily="monospace" FontSize="11" FontAttributes="Bold"
                           TextColor="#00FF41" HorizontalOptions="Center"
                           CharacterSpacing="1.5"/>

                    <Label Text="{Binding LockMessage}"
                           FontFamily="monospace" FontSize="12"
                           TextColor="#FF4141" HorizontalOptions="Center"
                           IsVisible="{Binding LockMessage, Converter={StaticResource NullToBoolConverter}}"/>

                    <Label Text="> USE PIN INSTEAD _"
                           FontFamily="monospace" FontSize="14" FontAttributes="Bold"
                           TextColor="#00FF41" HorizontalOptions="Center">
                        <Label.GestureRecognizers>
                            <TapGestureRecognizer Command="{Binding SwitchToPinCommand}"/>
                        </Label.GestureRecognizers>
                    </Label>
                </VerticalStackLayout>

                <!-- ── PIN PAD ── -->
                <VerticalStackLayout IsVisible="{Binding ShowingPinPad}" Spacing="18">

                    <!-- PIN indicator row -->
                    <VerticalStackLayout Spacing="10" HorizontalOptions="Center">
                        <Label Text="ENTER ACCESS CODE"
                               FontFamily="monospace" FontSize="9"
                               TextColor="#1A6A1A" CharacterSpacing="2.5"
                               HorizontalOptions="Center"/>

                        <HorizontalStackLayout Spacing="16" HorizontalOptions="Center">
                            <Ellipse WidthRequest="14" HeightRequest="14"
                                     Fill="{Binding PinDisplay, Converter={StaticResource PinDotConverter}, ConverterParameter=1}"/>
                            <Ellipse WidthRequest="14" HeightRequest="14"
                                     Fill="{Binding PinDisplay, Converter={StaticResource PinDotConverter}, ConverterParameter=2}"/>
                            <Ellipse WidthRequest="14" HeightRequest="14"
                                     Fill="{Binding PinDisplay, Converter={StaticResource PinDotConverter}, ConverterParameter=3}"/>
                            <Ellipse WidthRequest="14" HeightRequest="14"
                                     Fill="{Binding PinDisplay, Converter={StaticResource PinDotConverter}, ConverterParameter=4}"/>
                        </HorizontalStackLayout>

                        <Label Text="{Binding LockMessage}"
                               FontFamily="monospace" FontSize="12"
                               TextColor="#FF4141" HorizontalOptions="Center"
                               IsVisible="{Binding LockMessage, Converter={StaticResource NullToBoolConverter}}"/>
                    </VerticalStackLayout>

                    <!-- Numpad -->
                    <Grid ColumnDefinitions="*,*,*" RowDefinitions="Auto,Auto,Auto,Auto"
                          RowSpacing="10" ColumnSpacing="10"
                          HorizontalOptions="Center" WidthRequest="268">

                        <Button Grid.Row="0" Grid.Column="0" Text="1" Style="{StaticResource MatrixNumPad}" Command="{Binding PressDigitCommand}" CommandParameter="1"/>
                        <Button Grid.Row="0" Grid.Column="1" Text="2" Style="{StaticResource MatrixNumPad}" Command="{Binding PressDigitCommand}" CommandParameter="2"/>
                        <Button Grid.Row="0" Grid.Column="2" Text="3" Style="{StaticResource MatrixNumPad}" Command="{Binding PressDigitCommand}" CommandParameter="3"/>

                        <Button Grid.Row="1" Grid.Column="0" Text="4" Style="{StaticResource MatrixNumPad}" Command="{Binding PressDigitCommand}" CommandParameter="4"/>
                        <Button Grid.Row="1" Grid.Column="1" Text="5" Style="{StaticResource MatrixNumPad}" Command="{Binding PressDigitCommand}" CommandParameter="5"/>
                        <Button Grid.Row="1" Grid.Column="2" Text="6" Style="{StaticResource MatrixNumPad}" Command="{Binding PressDigitCommand}" CommandParameter="6"/>

                        <Button Grid.Row="2" Grid.Column="0" Text="7" Style="{StaticResource MatrixNumPad}" Command="{Binding PressDigitCommand}" CommandParameter="7"/>
                        <Button Grid.Row="2" Grid.Column="1" Text="8" Style="{StaticResource MatrixNumPad}" Command="{Binding PressDigitCommand}" CommandParameter="8"/>
                        <Button Grid.Row="2" Grid.Column="2" Text="9" Style="{StaticResource MatrixNumPad}" Command="{Binding PressDigitCommand}" CommandParameter="9"/>

                        <!-- Bottom row: bio (if on) | 0 | backspace -->
                        <Button Grid.Row="3" Grid.Column="0" Text="⬡"
                                Style="{StaticResource MatrixNumPad}" FontSize="22"
                                IsVisible="{Binding BiometricAvailable}"
                                Command="{Binding SwitchToBiometricCommand}"/>
                        <BoxView Grid.Row="3" Grid.Column="0" BackgroundColor="Transparent"
                                 IsVisible="{Binding BiometricAvailable, Converter={StaticResource InvertBoolConverter}}"/>
                        <Button Grid.Row="3" Grid.Column="1" Text="0" Style="{StaticResource MatrixNumPad}" Command="{Binding PressDigitCommand}" CommandParameter="0"/>
                        <Button Grid.Row="3" Grid.Column="2" Text="⌫" Style="{StaticResource MatrixNumPad}" Command="{Binding BackspaceCommand}"/>

                    </Grid>

                </VerticalStackLayout>

            </Grid>

        </Grid>
    </Grid>

</ContentPage>
