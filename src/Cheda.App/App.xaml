<?xml version = "1.0" encoding = "UTF-8" ?>
<Application xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:local="clr-namespace:Cheda.App"
             xmlns:conv="clr-namespace:Cheda.App.Converters"
             x:Class="Cheda.App.App">
    <Application.Resources>
        <ResourceDictionary>
            <ResourceDictionary.MergedDictionaries>
                <ResourceDictionary Source="Resources/Styles/Colors.xaml" />
                <ResourceDictionary Source="Resources/Styles/Styles.xaml" />
            </ResourceDictionary.MergedDictionaries>

            <!-- Converters available to all pages via StaticResource -->
            <conv:NullToBoolConverter     x:Key="NullToBoolConverter"/>
            <conv:InvertBoolConverter     x:Key="InvertBoolConverter"/>
            <conv:GreaterThanZeroConverter x:Key="GreaterThanZeroConverter"/>
            <conv:EqualConverter          x:Key="EqualConverter"/>
            <conv:PinDotConverter         x:Key="PinDotConverter"/>
            <conv:BoolToChevronConverter  x:Key="BoolToChevronConverter"/>
        </ResourceDictionary>
    </Application.Resources>
</Application>
